// AniVerse — PostgreSQL schema
// Designed to match the UI flows: auth, onboarding, watchlist, collections,
// communities, reviews, notifications, and analytics.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & identity ─────────────────────────────────────────────────────────

enum PlatformRole {
  USER
  CONTENT_ADMIN
  MUSIC_ADMIN
  ARTIST_ADMIN
  SUPER_ADMIN
}

model User {
  id                    String       @id @default(cuid())
  email                 String       @unique
  emailVerified         DateTime?
  handle                String       @unique
  name                  String
  passwordHash          String?
  role                  PlatformRole @default(USER)
  avatarColor           String       @default("#ff00cc")
  avatarUrl             String?
  portraitUrl           String?
  bio                   String       @default("")
  location              String       @default("")
  aiTasteScore          Int          @default(0)
  onboardingCompletedAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  accounts              Account[]
  tasteProfile          TasteProfile?
  preferences           UserPreferences?
  watchlistItems        WatchlistItem[]
  collections           Collection[]
  reviews               Review[]
  notifications         Notification[]
  communityMemberships  CommunityMember[]
  communityPosts        CommunityPost[]
  ratings               Rating[]
  watchEvents           WatchEvent[]
  listenEvents          ListenEvent[]

  @@index([handle])
}

/// OAuth accounts (Google, Discord) — NextAuth standard shape.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Onboarding taste test results — persisted after quiz completion.
model TasteProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tasteScore     Int
  summaryChips   Json     @default("[]")
  tasteBreakdown Json     @default("[]")
  selections     Json     @default("{}")
  goalLinks      Json     @default("[]")
  completedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Settings page — notification, privacy, and app preferences.
model UserPreferences {
  id               String  @id @default(cuid())
  userId           String  @unique
  newEpisodes      Boolean @default(true)
  watchParties     Boolean @default(true)
  musicDrops       Boolean @default(true)
  communityPosts   Boolean @default(false)
  weeklyRecap      Boolean @default(true)
  emailDigest      Boolean @default(false)
  publicProfile    Boolean @default(true)
  showActivity     Boolean @default(true)
  showWatchHistory Boolean @default(false)
  allowMessages    Boolean @default(true)
  language         String  @default("English")
  autoplayPreviews Boolean @default(true)
  spoilerWarnings  Boolean @default(true)
  matureContent    Boolean @default(false)
  reducedMotion    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Content catalog ─────────────────────────────────────────────────────────

enum MediaType {
  ANIME
  SHOW
  MOVIE
  DOCUMENTARY
  KDRAMA
  SONG
  ALBUM
  ARTIST
  PLAYLIST
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model Content {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  nativeTitle String?
  type        MediaType
  description String?   @db.Text
  synopsis    String?   @db.Text
  imageUrl    String?
  backdropUrl String?
  rating      Float?
  year        Int?
  accent      String?
  meta        String?
  trendingLabel String?
  creditLabel   String?
  /// Display chips on the detail hero (e.g. "All Seasons", "12 Episodes"). AI Match % is computed per user — not stored here.
  highlightTags Json    @default("[]")
  studio          String?
  director        String?
  originalAuthor  String?
  sourceMaterial  String?
  producers       String?
  network         String?
  country         String?
  composer        String?
  status          String?
  ageRating       String?
  imdbRating      Float?
  malScore        Float?
  airedFrom       String?
  airedTo         String?
  broadcast       String?
  episodeDuration String?
  airingDay       String?
  seasonLabel     String?
  lastUpdate      String?
  languages       Json    @default("[]")
  seasonCount     Int?
  episodeCount    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  genres           ContentGenre[]
  watchlistItems   WatchlistItem[]
  collectionItems  CollectionItem[]
  reviews          Review[]
  ratings          Rating[]
  watchEvents      WatchEvent[]
  sourceTracks     MusicTrack[]
  seasons          ContentSeason[]
  episodes         ContentEpisode[]
  characters       ContentCharacter[]
  featuredTracks   ContentFeaturedTrack[]
  relatedFrom      ContentRelated[]     @relation("ContentRelatedFrom")
  relatedTo        ContentRelated[]     @relation("ContentRelatedTo")
  catalogReviews   CatalogReview[]

  @@index([type])
  @@index([slug])
}

model ContentSeason {
  id           String   @id @default(cuid())
  contentId    String
  label        String
  episodeCount Int      @default(0)
  position     Int      @default(0)

  content  Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes ContentEpisode[]

  @@index([contentId])
}

model ContentEpisode {
  id            String  @id @default(cuid())
  contentId     String
  seasonId      String?
  seasonNumber  Int     @default(1)
  number        Int
  title         String
  duration      String?
  description   String? @db.Text
  thumbnailUrl  String?
  releaseDate   String?
  language      String?
  rating        Float?
  position      Int     @default(0)

  content Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  season  ContentSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([contentId])
  @@index([seasonId])
}

model ContentCharacter {
  id         String  @id @default(cuid())
  contentId  String
  name       String
  role       String?
  voiceActor String?
  imageUrl   String?
  accent     String?
  position   Int     @default(0)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentFeaturedTrack {
  contentId String
  trackId   String
  position  Int    @default(0)

  content Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  track   MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([contentId, trackId])
  @@index([contentId])
}

model ContentRelated {
  contentId String
  relatedId String
  position  Int    @default(0)

  content Content @relation("ContentRelatedFrom", fields: [contentId], references: [id], onDelete: Cascade)
  related Content @relation("ContentRelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([contentId, relatedId])
  @@index([contentId])
}

/// Admin-curated reviews shown on catalog detail pages (not user-submitted).
model CatalogReview {
  id                String   @id @default(cuid())
  contentId         String?
  trackId           String?
  artistId          String?
  authorName        String
  authorAvatarColor String?  @default("#ff00cc")
  rating            Float
  headline          String?
  body              String   @db.Text
  accent            String?
  likeCount         Int      @default(0)
  position          Int      @default(0)
  createdAt         DateTime @default(now())

  content Content?    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  track   MusicTrack? @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist  Artist?     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([trackId])
  @@index([artistId])
}

model Genre {
  id       String         @id @default(cuid())
  label    String         @unique
  contents ContentGenre[]
}

model ContentGenre {
  contentId String
  genreId   String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
}

model MusicTrack {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  nativeTitle     String?
  artist          String
  kind            String
  description     String?  @db.Text
  source          String?
  album           String?
  language        String?
  genres          Json     @default("[]")
  rating          Float?
  year            Int?
  durationLabel   String?
  durationSeconds Int?
  imageUrl        String?
  backdropUrl     String?
  accent          String?
  trendingLabel   String?
  creditLabel     String?
  featuredRank    Int?
  artistId        String?
  contentId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artistRef       Artist?                @relation(fields: [artistId], references: [id], onDelete: SetNull)
  sourceContent   Content?               @relation(fields: [contentId], references: [id], onDelete: SetNull)
  featuredOn      ContentFeaturedTrack[]
  collectionItems CollectionItem[]
  listenEvents    ListenEvent[]
  reviews         Review[]
  catalogReviews  CatalogReview[]

  @@index([slug])
  @@index([artistId])
  @@index([contentId])
}

model Artist {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  nativeTitle String?
  synopsis    String?  @db.Text
  imageUrl    String?
  accent      String?
  rating      Float?
  rankLeft    String?
  rankRight   String?
  primaryTags Json     @default("[]")
  languages   Json     @default("[]")
  genres      Json     @default("[]")
  label       String?
  debutYear   Int?
  isGroup     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        ArtistMember[]
  tracks         MusicTrack[]
  reviews        Review[]
  catalogReviews CatalogReview[]

  @@index([slug])
}

/// Band / group members when `Artist.isGroup` is true (e.g. TWICE).
model ArtistMember {
  id       String @id @default(cuid())
  artistId String
  name     String
  role     String?
  position Int    @default(0)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

// ─── User libraries ──────────────────────────────────────────────────────────

enum WatchlistPriority {
  NORMAL
  HIGH
}

enum WatchlistStatus {
  PENDING
  WATCHING
  COMPLETED
  DROPPED
}

model WatchlistItem {
  id        String            @id @default(cuid())
  userId    String
  contentId String
  priority  WatchlistPriority @default(NORMAL)
  status    WatchlistStatus   @default(PENDING)
  addedAt   DateTime          @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
}

model Collection {
  id            String     @id @default(cuid())
  slug          String     @unique
  userId        String
  name          String
  description   String?    @db.Text
  category      String     @default("Mixed")
  genreLabels   String[]   @default([])
  kind          String     @default("content")
  visibility    Visibility @default(PUBLIC)
  accent        String?
  imageUrl      String?
  itemCount     Int        @default(0)
  favoriteCount Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId])
  @@index([slug])
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  contentId    String?
  trackId      String?
  position     Int      @default(0)
  addedAt      DateTime @default(now())

  collection Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  content    Content?    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  track      MusicTrack? @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

// ─── Communities & social ────────────────────────────────────────────────────

enum MemberRole {
  ADMIN
  MODERATOR
  MEMBER
}

model Community {
  id            String     @id @default(cuid())
  slug          String     @unique
  name          String
  category      String
  description   String?    @db.Text
  visibility    Visibility @default(PUBLIC)
  activityLevel String?
  accent        String?
  imageUrl      String?
  wallpaperUrl  String?
  memberCount   Int        @default(0)
  postCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  members CommunityMember[]
  posts   CommunityPost[]

  @@index([slug])
}

model CommunityMember {
  id          String     @id @default(cuid())
  userId      String
  communityId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId])
}

model CommunityPost {
  id           String   @id @default(cuid())
  communityId  String
  authorId     String
  content      String   @db.Text
  imageUrl     String?
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  shareCount   Int      @default(0)
  createdAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([communityId])
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  contentId String?
  trackId   String?
  artistId  String?
  rating    Float
  headline  String?
  body      String   @db.Text
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  author  User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content Content?    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  track   MusicTrack? @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist  Artist?     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    String?
  description String?  @db.Text
  imageUrl    String?
  href        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Analytics events ────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  score     Float
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model WatchEvent {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  minutes   Int
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
}

model ListenEvent {
  id         String   @id @default(cuid())
  userId     String
  trackId    String
  minutes    Int
  listenedAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, listenedAt])
}
